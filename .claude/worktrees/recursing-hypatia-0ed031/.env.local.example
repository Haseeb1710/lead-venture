# Lead Venture — required environment variables

# Resend (https://resend.com) — used by the contact form server action.
# Without these, the form will return a graceful error to the user.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CONTACT_TO_EMAIL=leads@yourdomain.com
CONTACT_FROM_EMAIL=Lead Venture <hello@yourdomain.com>

# Used by app/sitemap.ts, app/robots.ts, and metadataBase.
NEXT_PUBLIC_SITE_URL=https://leadventure.example
